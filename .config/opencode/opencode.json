  "plugin": [
    "opencode-claude-auth",
    "opencode-gemini-auth@latest",
    "@nick-vi/opencode-type-inject",
    "opencode-websearch-cited@1.2.0",
    "opencode-wakatime",
    "octto",
  ],
  "mcp": {
    "type-inject": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@nick-vi/type-inject-mcp"
      ]
    },
    "pencil": {
      "command": [
        "/Users/patrickdev/.cursor/extensions/highagency.pencildev-0.6.33-universal/out/mcp-server-darwin-arm64",
        "--app",
        "cursor"
      ],
      "enabled": true,
      "type": "local"
    }
  }
