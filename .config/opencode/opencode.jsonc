  //         "reasoning": false
  //       },
  //       "deepseek-coder-v2:16b": {
  //         "name": "DeepSeek Coder V2 Lite 16B",
  //         "reasoning": false
  //       }
  //     }
  //   }
  // },
  "mcp": {
    "pencil": {
      "type": "local",
      "command": [
        "/Applications/Pencil.app/Contents/Resources/app.asar.unpacked/out/mcp-server-darwin-arm64",
        "--app",
        "desktop"
      ],
      "enabled": false
    }
  },
}
