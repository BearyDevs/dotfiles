{
  "$schema": "https://opencode.ai/config.json",
  "snapshot": false,
  "permission": {
    "skill": {
      "*": "allow",
      "pr-review": "allow",
      "internal-*": "allow",
      "experimental-*": "ask"
    }
  },
  "plugin": [
    "opencode-claude-auth",
    "@nick-vi/opencode-type-inject",
    "opencode-gemini-auth@latest",
    "opencode-zellij-namer",
    //   "octto"
  ],
  // "provider": {
  //   "ollama": {
  //     "npm": "@ai-sdk/openai-compatible",
  //     "name": "Ollama (local)",
