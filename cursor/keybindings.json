// Place your key bindings in this file to override the defaults
[
    {
        "key": "cmd+i",
        "command": "composerMode.agent"
    },
    {
        "key": "cmd+m",
        "command": "cursor.generateGitCommitMessage"
    },
    {
        "key": "cmd+shift+down",
        "command": "editor.action.marker.next",
        "when": "editorFocus"
    },
    {
        "key": "cmd+shift+up",
        "command": "editor.action.marker.prev",
        "when": "editorFocus"
    }
]